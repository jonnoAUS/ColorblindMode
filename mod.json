{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081"
    },
    "id": "realgares.colorblind-mode",
    "name": "Colorblind Mode",
    "version": "v1.0.0",
    "developer": "RealGares",
    "description": "Adds colorblind accessibility filters.",
    "tags": [
        "enhancement",
        "customization",
        "interface",
        "universal"
    ],
    "settings": {
        "general-title": {
            "type": "title",
            "name": "Colorblind Filters"
        },
        "enabled": {
            "type": "bool",
            "name": "Enable Colorblind Filter",
            "description": "Master toggle for all colorblind correction filters.",
            "default": false
        },
        "filter-mode": {
            "type": "string",
            "name": "Filter Type",
            "description": "Select which type of color vision deficiency to correct for.",
            "default": "Deuteranopia",
            "one-of": [
                "Protanopia",
                "Deuteranopia",
                "Tritanopia"
            ],
            "enable-if": "enabled"
        },
        "filter-strength": {
            "type": "float",
            "name": "Filter Strength",
            "description": "How strongly the colorblind correction is applied. 1.0 = full correction.",
            "default": 1,
            "min": 0,
            "max": 1,
            "control": {
                "slider": true,
                "slider-step": 0.05,
                "arrows": false,
                "input": true
            },
            "enable-if": "enabled"
        },
        "ui-title": {
            "type": "title",
            "name": "UI Options"
        },
        "show-menu-button": {
            "type": "bool",
            "name": "Show Menu Button",
            "description": "Display a quick-toggle button on the main menu for fast access.",
            "default": true
        },
        "show-indicator": {
            "type": "bool",
            "name": "Show Active Indicator",
            "description": "Show a small icon in gameplay when a colorblind filter is active.",
            "default": true,
            "enable-if": "enabled"
        }
    }
}